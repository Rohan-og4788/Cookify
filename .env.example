# Database
DATABASE_URL="postgresql://user:password@localhost:5432/recipe_finder?schema=public"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# OAuth Providers
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# External Recipe APIs
THEMEALDB_API_URL="https://www.themealdb.com/api/json/v1/1"
SPOONACULAR_API_KEY=""

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Resend (email notifications)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Recipe Finder <notifications@yourdomain.com>"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
